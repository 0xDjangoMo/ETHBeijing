    <section class="eb26-section eb26-supporters" id="supporters">
      <div class="eb26-section-head">
        <p class="eb26-kicker">{c.supportersEyebrow}</p>
        <h2>{c.supportersTitle} <em>{c.supportersTitleEm}</em></h2>
        <p>{c.supportersBody}</p>
      </div>

      <div class="eb26-supporters-stack">
