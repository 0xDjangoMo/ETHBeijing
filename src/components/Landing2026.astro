        </div>

        <div class="eb26-logo-group">
          <h3>{c.partnersTitle}</h3>
          <div class="eb26-logo-grid eb26-logo-grid--partners">
            {partnerLogos.map((item) => (
              <div class="eb26-logo-cell">
                <img src={item.img} alt={item.label} loading="lazy" onload="this.parentElement.classList.add('has-logo')" onerror="this.remove()" />
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="eb26-logo-group">
          <h3>{c.mediaTitle}</h3>
          <div class="eb26-logo-grid eb26-logo-grid--media">
            {mediaLogos.map((item) => (
              <div class="eb26-logo-cell">
                <img src={item.img} alt={item.label} loading="lazy" onload="this.parentElement.classList.add('has-logo')" onerror="this.remove()" />
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="eb26-logo-group">
          <h3>{c.universityTitle}</h3>
          <div class="eb26-logo-grid eb26-logo-grid--university">
            {universityLogos.map((item) => (
              <div class="eb26-logo-cell eb26-logo-cell--small">
                <img src={item.img} alt={item.label} loading="lazy" onload="this.parentElement.classList.add('has-logo')" onerror="this.remove()" />
                <span>{item.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="eb26-section eb26-faq" id="faq">
      <p class="eb26-kicker">{c.faqEyebrow}</p>
      <h2>{c.faqTitle} <em>{c.faqTitleEm}</em></h2>
      <div class="eb26-faq-list">
        {c.faqs.map(([q, a], index) => (
          <details open={index === 0}>
            <summary><span>0{index + 1}</span>{q}</summary>
            <p>{a}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="eb26-final">
      <h2>{c.ctaTitle}</h2>
      <p>{c.ctaBody}</p>
      <a class="eb26-button eb26-button-primary eb26-button-large" href={applyUrl} target="_blank" rel="noreferrer">{c.primary}</a>
    </section>
