      <a class="eb26-lang" href={langHref}>{langLabel}</a>
      <a class="eb26-button eb26-button-primary" href={applyUrl} target="_blank" rel="noreferrer">{c.apply}</a>
    </div>
  </nav>

  <header class="eb26-hero" id="hero">
