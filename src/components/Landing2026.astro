  <footer class="eb26-footer">
    <span>ETH//BJ '26</span>
    <p>{c.footer}</p>
  </footer>
</div>

<script>
  const root = document.querySelector(".eb26");
  const button = document.querySelector("[data-theme-toggle]");
  const storageKey = "ethbeijing-theme";
  const storedTheme = localStorage.getItem(storageKey);
  const initialTheme = storedTheme === "dark" ? "dark" : "light";

  const setTheme = (theme: string) => {
    root?.setAttribute("data-theme", theme);
    document.documentElement.setAttribute("data-theme", theme);
    button?.setAttribute("aria-label", theme === "dark" ? "Switch to light mode" : "Switch to dark mode");
    localStorage.setItem(storageKey, theme);
  };

  setTheme(initialTheme);
  button?.addEventListener("click", () => {
    const nextTheme = root?.getAttribute("data-theme") === "dark" ? "light" : "dark";
    setTheme(nextTheme);
  });
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
    background: oklch(0.985 0.003 250);
  }

  :global(body) {
    margin: 0;
    background: oklch(0.985 0.003 250);
    color: oklch(0.18 0.012 250);
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 14px;
    line-height: 1.55;
    letter-spacing: 0.005em;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  :global(html[data-theme="dark"]),
  :global(html[data-theme="dark"] body) {
    background: oklch(0.13 0.01 250);
    color: oklch(0.96 0.005 250);
  }

  .eb26,
  .eb26[data-theme="light"] {
    --bg: oklch(0.985 0.003 250);
    --bg-deep: oklch(0.97 0.004 250);
    --bg-elev: oklch(0.965 0.004 250);
    --bg-card: oklch(0.95 0.005 250);
    --line: oklch(0.82 0.008 250);
    --line-soft: oklch(0.9 0.006 250);
    --fg: oklch(0.18 0.012 250);
    --fg-mute: oklch(0.4 0.012 250);
    --fg-dim: oklch(0.55 0.012 250);
    --on-accent: oklch(0.13 0.01 250);
    --grid-line: oklch(0 0 0 / 0.045);
    --grid-line-strong: oklch(0 0 0 / 0.08);
    --scan: oklch(0 0 0 / 0.018);
    --topbar-bg: oklch(0.985 0.003 250 / 0.82);
    --chip-bg: oklch(0 0 0 / 0.025);
    --map-stripe: oklch(0 0 0 / 0.04);
    --scan-blend: multiply;
    --logo-cell-bg: oklch(0.965 0.004 250);
    --logo-filter: saturate(0.85) brightness(0.98) contrast(0.95);
    --logo-filter-hover: saturate(1) brightness(1) contrast(1);
    --accent: oklch(0.62 0.16 145);
    --accent-soft: oklch(0.62 0.16 145 / 0.13);
    --accent-line: oklch(0.62 0.16 145 / 0.45);
    --warn: oklch(0.85 0.16 85);
    --gold: oklch(0.85 0.13 85);
    --silver: oklch(0.78 0.01 250);
    --bronze: oklch(0.7 0.11 50);
    --mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, monospace;
    --display: "Space Grotesk", ui-sans-serif, system-ui, sans-serif;
    --radius: 4px;
    --radius-lg: 10px;
    min-height: 100vh;
    overflow: hidden;
    background: var(--bg);
    color: var(--fg);
    font-family: var(--mono);
  }

  .eb26[data-theme="dark"] {
    --bg: oklch(0.13 0.01 250);
    --bg-deep: oklch(0.1 0.008 250);
    --bg-elev: oklch(0.16 0.012 250);
    --bg-card: oklch(0.18 0.013 250);
    --line: oklch(0.28 0.015 250);
    --line-soft: oklch(0.22 0.013 250);
    --fg: oklch(0.96 0.005 250);
    --fg-mute: oklch(0.82 0.01 250);
    --fg-dim: oklch(0.65 0.012 250);
    --on-accent: oklch(0.13 0.01 250);
    --grid-line: oklch(1 0 0 / 0.025);
    --grid-line-strong: oklch(1 0 0 / 0.05);
    --scan: oklch(1 0 0 / 0.012);
    --topbar-bg: oklch(0.13 0.01 250 / 0.78);
    --chip-bg: oklch(1 0 0 / 0.02);
    --map-stripe: oklch(1 0 0 / 0.02);
    --scan-blend: overlay;
    --logo-cell-bg: oklch(0.18 0.013 250);
    --logo-filter: invert(1) hue-rotate(180deg) saturate(0.82) brightness(1.02) contrast(0.92);
    --logo-filter-hover: invert(1) hue-rotate(180deg) saturate(1) brightness(1.08) contrast(1);
    --accent: oklch(0.82 0.17 145);
    --accent-soft: oklch(0.82 0.17 145 / 0.14);
    --accent-line: oklch(0.82 0.17 145 / 0.42);
  }

  .eb26::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image:
      linear-gradient(to right, var(--grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-line) 1px, transparent 1px);
    background-size: 56px 56px;
    opacity: 1;
    mask-image: radial-gradient(ellipse at top, black 35%, transparent 80%);
  }

  .eb26::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      var(--scan) 2px,
      var(--scan) 3px
    );
    mix-blend-mode: var(--scan-blend);
  }

  .eb26 > * {
    position: relative;
    z-index: 1;
  }

  .eb26-nav {
    position: sticky;
    top: 0;
    z-index: 60;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    height: 56px;
    padding: 0 clamp(20px, 4vw, 48px);
    border-bottom: 1px solid var(--line-soft);
    background: var(--topbar-bg);
    backdrop-filter: blur(14px);
  }

  .eb26 a {
    color: inherit;
    text-decoration: none;
  }

  .eb26-brand,
  .eb26-nav-links,
  .eb26-nav-actions {
    display: flex;
    align-items: center;
  }

  .eb26-brand {
    gap: 10px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .eb26-live {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: eb26-pulse 1.6s ease-in-out infinite;
  }

  .eb26-muted {
    color: var(--fg-dim);
  }

  .eb26-nav-links {
    gap: 22px;
    color: var(--fg-mute);
    font-size: 12px;
  }

  .eb26-nav-links a {
    display: inline-flex;
    gap: 7px;
  }

  .eb26-nav-links span {
    color: var(--fg-dim);
    font-size: 10px;
  }

  .eb26-nav-links a:hover,
  .eb26-lang:hover {
    color: var(--accent);
  }

  .eb26-nav-actions {
    gap: 10px;
  }

  .eb26-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--bg-elev);
    color: var(--fg-mute);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
    -webkit-appearance: none;
    appearance: none;
  }

  .eb26-theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .eb26-theme-toggle__icon {
    display: none;
  }

  .eb26[data-theme="light"] .eb26-theme-toggle__icon--dark,
  .eb26[data-theme="dark"] .eb26-theme-toggle__icon--light {
    display: inline-flex;
  }

  .eb26-lang {
    color: var(--fg-mute);
    font-size: 12px;
  }

  .eb26-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0 16px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: transparent;
    color: var(--fg);
    font-family: var(--mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: transform 160ms ease, border-color 160ms ease, color 160ms ease;
  }

  .eb26-button:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
    color: var(--accent);
  }

  .eb26-button-primary {
    border-color: var(--accent);
    background: var(--accent);
    color: var(--on-accent);
    font-weight: 600;
  }

  .eb26-button-primary:hover {
    background: transparent;
    box-shadow: 0 0 24px var(--accent-soft);
  }

  .eb26-button-large {
    min-height: 48px;
    padding: 0 24px;
  }

  .eb26-hero {
    position: relative;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    min-height: calc(100vh - 56px);
    border-bottom: 1px solid var(--line-soft);
    overflow: hidden;
  }

  .eb26-hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 64px 48px 48px;
    border-right: 1px solid var(--line-soft);
    position: relative;
  }

  .eb26-kicker {
    margin: 0 0 16px;
    color: var(--fg-dim);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eb26 h1,
  .eb26 h2,
  .eb26 h3,
  .eb26 p {
    margin-top: 0;
  }

  .eb26 h1 {
    max-width: 760px;
    margin: 48px 0 0;
    font-family: var(--display);
    font-size: clamp(56px, 8.4vw, 128px);
    font-weight: 500;
    letter-spacing: -0.04em;
    line-height: 0.92;
  }

  .eb26 h1 span {
    color: var(--accent);
    font-style: italic;
    font-weight: 400;
  }

  .eb26-subtitle {
    display: block;
    margin: 28px 0 0;
    color: var(--fg-mute);
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eb26-intro {
    max-width: 460px;
    margin: 18px 0 0;
    color: var(--fg-mute);
    font-size: 14px;
    line-height: 1.55;
  }

  .eb26-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 40px;
    margin-bottom: 0;
  }

  .eb26-stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin-top: 56px;
    border: 1px solid var(--line-soft);
    background: var(--line-soft);
  }

  .eb26-stats div {
    padding: 18px 16px;
    border-right: 0;
    background: var(--bg);
  }

  .eb26-stats span {
    display: block;
    margin-bottom: 8px;
    color: var(--fg-dim);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .eb26-stats strong {
    color: var(--fg);
    font-family: var(--display);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .eb26-terminal {
    position: relative;
    align-self: stretch;
    margin: 32px;
    border: 1px solid var(--line);
    border-radius: 10px;
    background: var(--bg-deep);
    box-shadow: none;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .eb26-hero > .eb26-terminal {
    min-height: auto;
  }

  .eb26-hero::after {
    content: "";
    position: absolute;
    inset: 0 0 0 auto;
    width: 48%;
    background: var(--bg-deep);
    z-index: -1;
  }

  .eb26-terminal-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    height: 36px;
    padding: 0 14px;
    border-bottom: 1px solid var(--line);
    color: var(--fg-dim);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eb26-terminal-bar span {
    width: 9px;
    height: 9px;
    border-radius: 99px;
    background: var(--line);
  }

  .eb26-terminal-bar b {
    margin-left: auto;
    font-weight: 500;
  }

  .eb26-terminal pre {
    flex: 1;
    margin: 0;
    padding: 16px 18px;
    color: var(--fg-mute);
    font-size: 12.5px;
    line-height: 1.7;
    white-space: pre-wrap;
    word-break: break-word;
    overflow: hidden;
  }

  .prompt,
  .ok {
    color: var(--accent);
  }

  .cmd {
    color: var(--fg);
  }

  .out {
    color: var(--fg-mute);
  }

  .key {
    color: var(--gold);
  }

  .str {
    color: oklch(0.78 0.1 30);
  }

  .cursor {
    display: inline-block;
    width: 9px;
    height: 16px;
    background: var(--accent);
    vertical-align: -2px;
    animation: eb26-blink 1s steps(2, start) infinite;
  }

  .eb26-section {
    padding: 96px clamp(24px, 5vw, 72px);
    border-bottom: 1px solid var(--line-soft);
  }

  .eb26-section-head {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.55fr);
    gap: 40px;
    align-items: end;
    max-width: 1280px;
    margin: 0 auto 56px;
  }

  .eb26-section-head .eb26-kicker {
    grid-column: 1 / -1;
    margin-bottom: -20px;
  }

  .eb26 h2 {
    margin-bottom: 0;
    font-family: var(--display);
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
  }

  .eb26 h2 em {
    color: var(--accent);
    font-family: var(--mono);
    font-size: 0.65em;
    font-style: normal;
    font-weight: 400;
    letter-spacing: 0;
    vertical-align: 0.15em;
  }

  .eb26-section-head p:last-child,
  .eb26-track-card p,
  .eb26-venue-panel p,
  .eb26-final p {
    color: var(--fg-mute);
    font-size: 13px;
    line-height: 1.6;
  }

  .eb26-prize-grid {
    display: grid;
    grid-template-columns: minmax(260px, 0.7fr) minmax(0, 1.3fr);
    gap: 64px;
    max-width: 1280px;
    margin: 0 auto;
    align-items: start;
  }

  .eb26-pool,
  .eb26-winners article,
  .eb26-track-card,
  .eb26-days article,
  .eb26-venue-panel,
  .eb26-final {
    border: 1px solid var(--line);
    background: var(--bg-elev);
    border-radius: var(--radius-lg);
  }

  .eb26-pool {
    display: flex;
    min-height: auto;
    flex-direction: column;
    justify-content: space-between;
    padding: 32px;
    background:
      radial-gradient(circle at 24% 18%, var(--accent-soft), transparent 58%),
      var(--bg-elev);
    position: relative;
    overflow: hidden;
  }

  .eb26-pool::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, var(--grid-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--grid-line) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }

  .eb26-pool > * {
    position: relative;
  }

  .eb26-pool span {
    color: var(--fg-dim);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .eb26-pool strong {
    color: var(--fg);
    font-family: var(--display);
    font-size: clamp(64px, 7vw, 88px);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  .eb26-winners {
    display: grid;
    gap: 12px;
  }

  .eb26-winners article {
    display: grid;
    grid-template-columns: 80px minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    padding: 24px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .eb26-winners article:hover {
    border-color: var(--accent-line);
    transform: translateX(4px);
  }

  .eb26-winners article > span {
    color: var(--accent);
    font-family: var(--display);
    font-size: 64px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .eb26-winners article:nth-child(2) > span {
    color: var(--silver);
  }

  .eb26-winners article:nth-child(3) > span {
    color: var(--bronze);
  }

  .eb26-winners h3 {
    margin-bottom: 6px;
    font-family: var(--display);
    font-size: 22px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .eb26-winners p {
    margin-bottom: 0;
    color: var(--fg-mute);
    font-size: 12px;
  }

  .eb26-winners strong {
    color: var(--fg);
    font-family: var(--display);
    font-size: 36px;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .eb26-track {
    padding-top: clamp(84px, 11vw, 148px);
    padding-bottom: clamp(84px, 11vw, 148px);
  }

  .eb26-track-card {
    position: relative;
    overflow: hidden;
    max-width: 1280px;
    margin: 0 auto;
    padding: 36px;
    border-color: var(--accent-line);
    background:
      radial-gradient(ellipse at top right, var(--accent-soft), transparent 70%),
      var(--bg-elev);
  }

  .eb26-track-card::after {
    content: "AI x WEB3";
    position: absolute;
    right: -0.08em;
    bottom: -0.26em;
    color: var(--grid-line-strong);
    font-family: var(--display);
    font-size: clamp(80px, 18vw, 240px);
    letter-spacing: -0.08em;
    pointer-events: none;
  }

  .eb26-track-card h2,
  .eb26-track-card p,
  .eb26-track-card .eb26-kicker,
  .eb26-chip-row {
    position: relative;
    z-index: 1;
  }

  .eb26-track-card p {
    max-width: 640px;
    margin: 16px 0 22px;
  }

  .eb26-chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    max-width: 760px;
  }

  .eb26-chip-row span {
    border: 1px solid var(--line);
    border-radius: 3px;
    padding: 5px 9px;
    color: var(--fg-mute);
    background: var(--chip-bg);
    font-size: 10.5px;
    letter-spacing: 0.06em;
  }

  .eb26-chip-row span:nth-child(-n + 2) {
    color: var(--accent);
    border-color: var(--accent-line);
  }

  .eb26-days {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .eb26-days article {
    padding: 26px;
  }

  .eb26-days span {
    color: var(--accent);
    font-size: 11px;
    letter-spacing: 0.18em;
  }

  .eb26-days h3 {
    margin: 18px 0 12px;
    font-family: var(--display);
    font-size: 28px;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  .eb26-days p {
    margin-bottom: 0;
    color: var(--fg-mute);
    line-height: 1.65;
  }

  .eb26-venue {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(320px, 1.2fr);
    gap: 36px;
    align-items: start;
    max-width: 1280px;
    margin-left: auto;
    margin-right: auto;
  }

  .eb26-venue-panel {
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) minmax(0, 1fr);
    overflow: hidden;
    background: var(--bg-elev);
  }

  .eb26-map {
    position: relative;
    min-height: 300px;
    border-right: 1px solid var(--line);
    background:
      repeating-linear-gradient(45deg, transparent 0 14px, var(--map-stripe) 14px 15px),
      repeating-linear-gradient(-45deg, transparent 0 14px, var(--map-stripe) 14px 15px),
      var(--bg);
    overflow: hidden;
  }

  .eb26-map img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 300px;
    object-fit: cover;
    filter: saturate(0.9) contrast(0.96) brightness(0.94);
    opacity: 0.92;
  }

  .eb26[data-theme="light"] .eb26-map img {
    filter: saturate(0.88) contrast(0.94) brightness(1.02);
    opacity: 0.9;
  }

  .eb26-map span {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 16px;
    border-radius: 99px;
    background: var(--accent);
    box-shadow: 0 0 20px var(--accent);
    transform: translate(-50%, -50%);
  }

  .eb26-venue-panel > div:last-child {
    padding: 32px;
  }

  .eb26-venue h3 {
    margin-bottom: 14px;
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .eb26-venue small {
    color: var(--fg-dim);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .eb26-supporters-stack {
    display: grid;
    gap: 52px;
    max-width: 1280px;
    margin: 0 auto;
  }

  .eb26-logo-group h3 {
    margin: 0 0 18px;
    color: var(--fg);
    font-family: var(--display);
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .eb26-logo-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--bg-elev);
    overflow: hidden;
  }

  .eb26-logo-grid--sponsors {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .eb26-logo-grid--partners,
  .eb26-logo-grid--media {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .eb26-logo-grid--university {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .eb26-logo-cell {
    position: relative;
    display: flex;
    min-height: 120px;
    align-items: center;
    justify-content: center;
    padding: 22px;
    border-right: 1px solid var(--line-soft);
    border-bottom: 1px solid var(--line-soft);
    background:
      radial-gradient(circle at 50% 35%, var(--grid-line-strong), transparent 68%),
      var(--logo-cell-bg);
    color: var(--fg-dim);
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 10.5px;
  }

  .eb26-logo-cell:nth-child(3n) {
    border-right: 0;
  }

  .eb26-logo-grid--university .eb26-logo-cell:nth-child(3n),
  .eb26-logo-grid--media .eb26-logo-cell:nth-child(3n),
  .eb26-logo-grid--partners .eb26-logo-cell:nth-child(3n) {
