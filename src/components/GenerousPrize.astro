---
import i18next from "i18next";
const cardData = [
  {
    img: "/images/dot-track1.png",
    prizes: [
      {
        rank: "1st",
        amount: "3000 ¥",
        accentClass: "bg-linear-to-r from-rose-500 to-pink-500 text-white",
        amountClass: "bg-rose-50 text-rose-900 border-rose-100",
      },
      {
        rank: "2nd",
        amount: "2000 ¥",
        accentClass: "bg-linear-to-r from-sky-500 to-blue-600 text-white",
        amountClass: "bg-sky-50 text-sky-900 border-sky-100",
      },
      {
        rank: "3rd",
        amount: "1000 ¥",
        accentClass: "bg-linear-to-r from-amber-400 to-orange-500 text-white",
        amountClass: "bg-orange-50 text-orange-900 border-orange-100",
      },
    ],
    specialAward: "1000 ¥",
  }
];
---

<section class="flex justify-center flex-col items-center mt-[200px]">
  <div id="prize" class="anchor"></div>
  <!-- <div class="bg"></div> -->
  <h1 class="font-bold text-4xl leading-[44px] h-[44px] mb-[60px]">
    {i18next.t("generousPrize.title")}
  </h1>
  <div class="title flex items-center gap-x-1 text-neutral-900">
    <img src="/images/union.svg" height="17.6" />
    <span class="text-neutral-900 text-lg font-semibold"
      >{i18next.t("generousPrize.prizePool")}</span
    >
  </div>
  <img class="h-[10px] mb-[44px]" src="/images/Vector (Stroke).svg" />
  <div class="flex flex-col items-center gap-[40px]">
    {
      cardData.map((item, idx) => {
        return (
          <div class="flex lg:items-center max-lg:flex-col">
            {/* <div class="flex items-center lg:pr-[56px] max-lg:pb-[30px] sm:justify-start justify-center">
              <img class="h-[24px] w-[24px] " src={item.img} />
              <h1 class="text-black font-semibold text-[24px] leading-[29px] w-[100px] pl-[10px]">
                {i18next.t(`generousPrize.cards.${idx}.track`)}
              </h1>
            </div> */}

            <div class="flex flex-col items-start rounded-[10px] border border-gray-300 bg-white px-[40px] py-[30px] shadow-[0px_2px_12px_rgba(0,0,0,0.06)] pb-[40px] sm:w-[600px]">
              <div>
                <h1 class="text-black font-semibold text-[18px] leading-[34px] pb-[16px] sm:text-left text-center">
                  {i18next.t(`generousPrize.cards.${idx}.title`)}
                </h1>
                {/* <div class="flex items-center pb-[40px]">
                  <img class="h-[15px] pr-[10px]" src="/images/info.png" />
                  <span class="text-neutral-900 text-base leading-[19px] ">
                    {i18next.t(`generousPrize.cards.${idx}.description`)}
                  </span>
                </div> */}
                <div class="flex items-start sm:items-center sm:gap-x-[12px] sm:flex-row max-lg:flex-col max-lg:gap-y-[12px]">
                  <p class="min-w-[72px] pt-[2px] text-xs font-medium tracking-[0.08em] text-gray-500">Prize</p>
                  <div class="flex flex-wrap gap-3">
                    {item.prizes.map((prize) => {
                      return (
                        <div class={`inline-flex overflow-hidden rounded-[10px] border shadow-[0px_1px_4px_rgba(244,63,94,0.12)] ${prize.amountClass}`}>
                          <span class={`px-4 py-2 text-sm font-semibold ${prize.accentClass}`}>
                            {prize.rank}
                          </span>
                          <span class="px-4 py-2 text-sm font-semibold">
                            {prize.amount}
                          </span>
                        </div>
                      );
                    })}
                  </div>
                </div>
                
                <div class="mt-4 flex items-start sm:items-center sm:gap-x-[12px] sm:flex-row max-lg:flex-col max-lg:gap-y-[12px]">
                  <p class="min-w-[72px] pt-[2px] text-xs font-medium tracking-[0.08em] text-gray-500">Special award</p>
                  <div class="inline-flex overflow-hidden rounded-[10px] border border-rose-100 shadow-[0px_1px_4px_rgba(244,63,94,0.12)]">
                    <span class="bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-900">
                      {item.specialAward}
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>

  <img
    class="w-[255px] origin-center absolute left-[-80px] z-[-1] top-[1896px]"
    src="/images/bg-ele-2.png"
  />
</section>
