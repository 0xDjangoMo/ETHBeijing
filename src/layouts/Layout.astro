---
import i18next from "i18next";
import { ensureI18n } from "../lib/i18n";
import "../styles/global.css";
export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = Astro.url.pathname.startsWith("/zh") ? "zh" : "en";
ensureI18n(locale);
const supportedLanguages = ["en", "zh"] as const;
const currentPath = Astro.url.pathname;

const localizedPath = (locale: "en" | "zh") => {
  if (locale === "en") {
    if (currentPath === "/zh" || currentPath === "/zh/") return "/";
    return currentPath;
  }

  if (currentPath === "/") return "/zh/";
  if (currentPath.startsWith("/zh/")) return currentPath;
  if (currentPath === "/zh") return "/zh/";
  return `/zh${currentPath}`;
};
---

<!DOCTYPE html>
<html lang={i18next.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,user-scalable=no,initial-scale=1.0,maximum-scale=1.0,minimum-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    {
      supportedLanguages.map((locale) => (
        <link
          rel="alternate"
          hreflang={locale}
          href={new URL(localizedPath(locale), Astro.url.origin).toString()}
        />
      ))
    }
  </head>
  <body class="font-inter">
    <slot />
    <style is:global>
      html {
        font-family: system-ui, sans-serif;
        background-color: #fff;
      }
    </style>
  </body>
</html>
