---
import i18next from "i18next";
import { ensureI18n } from "../lib/i18n";
import "../styles/global.css";
export interface Props {
  title: string;
}

const { title } = Astro.props;
const locale = Astro.url.pathname.startsWith("/zh") ? "zh" : "en";
ensureI18n(locale);
const supportedLanguages = ["en", "zh"] as const;
const currentPath = Astro.url.pathname;

const localizedPath = (locale: "en" | "zh") => {
  if (locale === "en") {
    if (currentPath === "/zh" || currentPath === "/zh/") return "/";
    return currentPath;
  }

  if (currentPath === "/") return "/zh/";
  if (currentPath.startsWith("/zh/")) return currentPath;
  if (currentPath === "/zh") return "/zh/";
  return `/zh${currentPath}`;
};
---

<!DOCTYPE html>
<html lang={i18next.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,user-scalable=no,initial-scale=1.0,maximum-scale=1.0,minimum-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="ETH Beijing 2026 is a 48-hour AI x Web3 hackathon in Beijing with one focused track and a $5,000 prize pool."
    />
    <title>{title}</title>
    {
      supportedLanguages.map((locale) => (
        <link
          rel="alternate"
          hreflang={locale}
          href={new URL(localizedPath(locale), Astro.url.origin).toString()}
        />
      ))
    }
  </head>
  <body>
    <slot />
    <style is:global>
      html {
        font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      }
    </style>
  </body>
</html>
